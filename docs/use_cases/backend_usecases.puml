@startuml
left to right direction
skinparam packageStyle rectangle

actor "User" as User
actor "Backend API" as Backend

package "Frontend Application" {

  rectangle "User Management (Auth)" {
    usecase "Login" as UC_Login
    usecase "Register Account" as UC_Register
  }

  rectangle "Video Processing & Analysis" {
    usecase "Start Video Analysis" as UC_Start
    usecase "Stream Video Frames\n(Simulation)" as UC_Stream
    usecase "Display Detected Sign Label" as UC_Result

    usecase "Browse Analysis History" as UC_History
    usecase "View Annotated Video" as UC_View
  }
}

' --- RELACJE AUTH ---
User --> UC_Login
User --> UC_Register


UC_Register -- Backend

' --- RELACJE WIDEO ---
User --> UC_Start

' Logika biznesowa
UC_Start ..> UC_Stream : <<include>>
UC_Start ..> UC_Result : <<include>>

' Połączenia z Backendem (Asocjacje)
' Używamy -- (bez strzałki), co oznacza wzajemną komunikację
UC_Stream -- Backend : "Uploads frames"
UC_Result -- Backend : "Retrieves label"

' Historia
User --> UC_History
UC_View .> UC_History : <<extend>>
UC_View -- Backend : "Fetches details"

@enduml